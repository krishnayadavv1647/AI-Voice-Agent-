PORT=5000

# --- Local development performance mode -------------------------------------
# NODE_ENV: "development" locally, "production" on the deployed server.
NODE_ENV=development
# RUN_WORKERS: master switch for ALL background jobs (campaign, follow-up, scheduled calls,
# email sync, telegram bot, pipeline scheduler). Leave false/unset locally so they don't steal
# CPU. Set to "true" only on the deployed Background Worker instance (or locally when testing a
# worker on purpose). Per-worker flags like CAMPAIGN_WORKER_ENABLED only apply once this is true.
RUN_WORKERS=false
# DEBUG_LOGS: off = quiet terminal. Set "true" to print per-request timing (METHOD URL status - ms)
# and verbose debug logs, so you can spot slow API routes locally.
DEBUG_LOGS=false
# ENABLE_GEMINI_KEEPWARM: keeps the Gemini connection warm with a real API call on startup + every
# 4 min. ON by default in production, OFF locally. Set "true" locally only if you need it.
ENABLE_GEMINI_KEEPWARM=false
# Frontend reads its API base from frontend/.env (NOT this file):
#   VITE_API_URL=http://localhost:5000/api

# ---------------------------------------------------------------------------

MONGODB_URI=
JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-backend-domain.com/api/auth/google/callback
TELEPHONY_SECRET_KEY=
SECRET_ENCRYPTION_KEY=
CARTESIA_API_VERSION=2026-03-01
DOGRAH_CARTESIA_STT_SUPPORTED=true
BACKEND_URL=http://localhost:5000
PUBLIC_BACKEND_URL=https://your-backend-domain.com
DOGRAH_API_KEY=
DOGRAH_BASE_URL=
DOGRAH_ALLOW_GLOBAL_FALLBACK=false
DOGRAH_CREATE_WORKFLOW_ENDPOINT=/workflow/create/definition
DEFAULT_CALLER_ID_NUMBER=+17578297060
DEFAULT_TELEPHONY_PROVIDER=twilio
DOGRAH_ENABLE_EXTRACTION=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
IMAGE_PROVIDER=kie
KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai
KIE_CREATE_TASK_ENDPOINT=/api/v1/jobs/createTask
KIE_IMAGE_MODEL=gpt-image-2-text-to-image
KIE_CALLBACK_URL=https://your-backend-domain.com/api/kie/callback
CLIENT_URL=http://localhost:5173
LEAD_FINDER_PROVIDER=mock
GOOGLE_PLACES_API_KEY=
SERPAPI_API_KEY=
SERP_API_KEY=
SERPAPI_KEY=
OUTSCRAPER_API_KEY=
APOLLO_API_KEY=
HUNTER_API_KEY=
EMAIL_PROVIDER=brevo
BREVO_API_KEY=
FROM_EMAIL=
FROM_NAME=
EMAIL_INBOUND_MODE=imap
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_APP_PASSWORD=
IMAP_POLL_INTERVAL_SECONDS=30
# --- Gmail email integration (active provider) ---
# Same Google OAuth client as login, but a SEPARATE callback URL (leave GOOGLE_REDIRECT_URI alone).
EMAIL_CREDENTIAL_ENCRYPTION_KEY=
GOOGLE_GMAIL_REDIRECT_URI=http://localhost:5000/api/email-integrations/gmail/callback
FRONTEND_URL=http://localhost:5173
EMAIL_SYNC_INTERVAL_SECONDS=60
EMAIL_SYNC_BATCH_SIZE=10
EMAIL_SYNC_CONCURRENCY=2
# Initial Gmail import bounds
GMAIL_INITIAL_SYNC_MAX_MESSAGES=500
GMAIL_INITIAL_SYNC_QUERY=newer_than:90d -in:chats
GMAIL_SYNC_PAGE_SIZE=100
# Gmail campaign worker (requires RUN_WORKERS=true)
GMAIL_CAMPAIGN_WORKER_ENABLED=true
GMAIL_CAMPAIGN_WORKER_INTERVAL_SECONDS=10
GMAIL_SEND_CONCURRENCY=1
GMAIL_SEND_DELAY_MS=5000
GMAIL_SEND_MAX_RETRIES=3
GMAIL_MAX_ATTACHMENT_MB=20
# GMAIL_DAILY_LIMITS={"free":25,"starter":75,"pro":150,"agency":250}
EMAIL_ALLOW_GLOBAL_FALLBACK=false
INBOUND_REPLY_DOMAIN=yourdomain.com
FOLLOWUP_RETRY_TEST_MODE=false
APPOINTMENT_TEST_MODE=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
CAMPAIGN_WORKER_ENABLED=true
CAMPAIGN_WORKER_INTERVAL_SECONDS=10
CAMPAIGN_MAX_PARALLEL_CALLS=3
CAMPAIGN_DEFAULT_BATCH_SIZE=5
CAMPAIGN_DEFAULT_DELAY_SECONDS=10
