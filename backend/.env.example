PORT=5000
MONGODB_URI=
JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-backend-domain.com/api/auth/google/callback
TELEPHONY_SECRET_KEY=
SECRET_ENCRYPTION_KEY=
CARTESIA_API_VERSION=2026-03-01
DOGRAH_CARTESIA_STT_SUPPORTED=true
BACKEND_URL=http://localhost:5000
PUBLIC_BACKEND_URL=https://your-backend-domain.com
DOGRAH_API_KEY=
DOGRAH_BASE_URL=https://app.dograh.com/api/v1
DEFAULT_CALLER_ID_NUMBER=+17578297060
DEFAULT_TELEPHONY_PROVIDER=twilio
DOGRAH_ENABLE_EXTRACTION=true
# --- Vapi (Layer A) ---
VAPI_PRIVATE_KEY=            # server-side REST auth (Bearer). Never sent to the browser.
VAPI_PUBLIC_KEY=             # browser Web SDK key (safe to expose to the client)
VAPI_BASE_URL=https://api.vapi.ai
VAPI_PHONE_NUMBER_ID=        # id of your Twilio number AFTER importing it into Vapi (BYO Twilio)
VAPI_CUSTOM_LLM_URL=         # e.g. https://<PUBLIC_BACKEND_URL>/api/vapi  (Vapi appends /chat/completions). Layer B serves it.
VAPI_WEBHOOK_SECRET=         # shared secret Vapi signs server messages with (used in Layer B)
VAPI_DEFAULT_VOICE_ID=       # fallback 11labs voiceId when the agent has no TTS voice configured
DEFAULT_LLM_PROVIDER=google_gemini   # engine fallback when agent.llmProvider is unset/legacy
# Gemini fallback configuration. GEMINI_API_KEY is only used if no UI connected
# account is selected for the agent.
GEMINI_API_KEY=
# gemini-2.5-flash is the recommended default for voice agents.
# gemini-2.5-flash-lite is fastest for simple FAQ/receptionist agents.
# gemini-2.5-pro is not recommended for live voice calls because it increases latency.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_TOKENS=96
OPENAI_API_KEY=
IMAGE_PROVIDER=kie
KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai
KIE_CREATE_TASK_ENDPOINT=/api/v1/jobs/createTask
KIE_IMAGE_MODEL=gpt-image-2-text-to-image
KIE_CALLBACK_URL=https://your-backend-domain.com/api/kie/callback
CLIENT_URL=http://localhost:5173
EMAIL_PROVIDER=brevo
BREVO_API_KEY=
FROM_EMAIL=
FROM_NAME=
EMAIL_INBOUND_MODE=imap
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_APP_PASSWORD=
IMAP_POLL_INTERVAL_SECONDS=30
# --- Payments ---
PAYMENT_PROVIDER=razorpay

# Razorpay (get from https://dashboard.razorpay.com → Settings → API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Stripe (only needed if you switch PAYMENT_PROVIDER=stripe)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxx
